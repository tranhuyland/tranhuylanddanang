import { NextResponse } from 'next/server';

// ĐƯỜNG LINK WEB APP GOOGLE APPS SCRIPT CỦA ANH HUY
const GOOGLE_SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbxrLhvyeMjS6lTQf0E66ZRUCgeGYDLI2UZgDsgm5-_kAX1s9ZA1_xYiE8u47b2h1ITQwA/exec';

export async function POST(request: Request) {
  try {
    const body = await request.json();

    // Gửi dữ liệu từ Server Vercel sang Google Sheet để né hoàn toàn lỗi CORS
    const response = await fetch(GOOGLE_SCRIPT_URL, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify(body),
    });

    const result = await response.json();
    return NextResponse.json(result);
  } catch (error) {
    console.error('Lỗi kết nối API:', error);
    return NextResponse.json(
      { success: false, message: 'Không thể kết nối đồng bộ dữ liệu với Google Sheet.' },
      { status: 500 }
    );
  }
}
