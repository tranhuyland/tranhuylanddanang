import { NextResponse } from 'next/server';

// 🚨 THAO TÁC BẮT BUỘC: Anh Huy thay thế đường link '/exec' mới toanh của anh vào đây nhé!
const GOOGLE_SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbzLqOHjZnOXCTSXSX36GXjMYBBY-7qFrtVwpAkBnBZV_KEFYbziMs6guhgk16PjP2mbTQ/exec';

// Cấu hình xử lý phương thức OPTIONS để thông luồng CORS cho trình duyệt di động
export async function OPTIONS() {
  return new NextResponse(null, {
    status: 200,
    headers: {
      'Access-Control-Allow-Origin': '*',
      'Access-Control-Allow-Methods': 'GET, POST, OPTIONS',
      'Access-Control-Allow-Headers': 'Content-Type',
    },
  });
}

// Xử lý nạp dữ liệu chính (POST Request) gửi sang Google Sheet
export async function POST(request: Request) {
  const headers = {
    'Access-Control-Allow-Origin': '*',
    'Access-Control-Allow-Methods': 'GET, POST, OPTIONS',
    'Access-Control-Allow-Headers': 'Content-Type',
  };

  try {
    // Đọc luồng dữ liệu JSON nhận được từ giao diện Website gửi vào
    const body = await request.json();

    // Thực hiện chuyển tiếp (Forward) dữ liệu một cách an toàn từ máy chủ Vercel sang Google API
    const googleResponse = await fetch(GOOGLE_SCRIPT_URL, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify(body),
    });

    // Ép kiểu kết quả phản hồi trả về từ cổng Google Apps Script
    const result = await googleResponse.json();

    // Trả phản hồi thành công về cho giao diện client đóng popup tải
    return NextResponse.json(result, { status: 200, headers });

  } catch (error: any) {
    // Trường hợp nghẽn mạng hoặc sai link, trả lỗi chi tiết dạng JSON để chống sập luồng hệ thống
    return NextResponse.json(
      { result: 'error', message: error.message || 'Lỗi kết nối API Server!' },
      { status: 500, headers }
    );
  }
}
